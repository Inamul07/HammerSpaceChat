{
	"name": "hammerspace-chat",
	"version": "0.1.0",
	"description": "AI Chat application with Normal Chat and RAG modes",
	"main": "dist-electron/main.js",
	"author": "HammerSpace Team",
	"license": "MIT",
	"private": true,
	"scripts": {
		"dev": "vite",
		"build": "npm run build:electron && vite build && electron-builder",
		"build:electron": "tsc -p tsconfig.electron.json",
		"build:electron:watch": "tsc -p tsconfig.electron.json --watch",
		"lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
		"preview": "vite preview",
		"electron:dev": "npm run build:electron && concurrently \"npm run build:electron:watch\" \"vite\" \"wait-on http://localhost:5173 && wait-on dist-electron/main.js && cross-env NODE_ENV=development electron .\"",
		"electron:build": "npm run build:electron && vite build && electron-builder"
	},
	"dependencies": {
		"@google/generative-ai": "^0.21.0",
		"antd": "^5.21.0",
		"pg": "^8.13.0",
		"pgvector": "^0.2.0",
		"zustand": "^4.5.0",
		"pdf-parse": "^1.1.1",
		"mammoth": "^1.8.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"@types/node": "^20.11.0",
		"@types/pg": "^8.11.0",
		"@types/pdf-parse": "^1.1.4",
		"@types/react": "^18.3.0",
		"@types/react-dom": "^18.3.0",
		"@typescript-eslint/eslint-plugin": "^6.21.0",
		"@typescript-eslint/parser": "^6.21.0",
		"@vitejs/plugin-react": "^4.2.1",
		"concurrently": "^8.2.2",
		"cross-env": "^7.0.3",
		"electron": "^28.2.0",
		"electron-builder": "^24.13.0",
		"eslint": "^8.56.0",
		"eslint-plugin-react-hooks": "^4.6.0",
		"eslint-plugin-react-refresh": "^0.4.5",
		"typescript": "^5.3.3",
		"vite": "^5.0.12",
		"vite-plugin-electron": "^0.28.0",
		"wait-on": "^7.2.0"
	},
	"build": {
		"appId": "com.hammerspace.chat",
		"productName": "HammerSpace Chat",
		"directories": {
			"output": "release"
		},
		"files": [
			"dist/**/*",
			"dist-electron/**/*"
		],
		"mac": {
			"target": "dmg"
		},
		"win": {
			"target": "nsis"
		},
		"linux": {
			"target": "AppImage"
		}
	}
}
