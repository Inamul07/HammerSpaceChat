{
	"extends": "./tsconfig.node.json",
	"compilerOptions": {
		"outDir": "dist-electron",
		"module": "CommonJS",
		"moduleResolution": "node",
		"target": "ES2020",
		"lib": ["ES2020"],
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"noEmit": false
	},
	"include": ["electron/**/*", "src/types/**/*"]
}
